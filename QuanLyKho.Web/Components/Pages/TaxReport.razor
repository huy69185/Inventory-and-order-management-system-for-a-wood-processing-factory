@page "/tax-report"
@using MudBlazor
@using QuanLyKho.Application.Interfaces
@using QuanLyKho.Domain.Entities
@using QuanLyKho.Web.Components.Pages.Shared
@using QuanLyKho.Web.Services

<PageTitle>Kê Khai Thuế</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true" Class="mb-4">Kê Khai Thuế (GTGT & TNCN 2026)</MudText>
    <MudAlert Severity="Severity.Info" Class="mb-4" Dense="true">
        Thuế GTGT và TNCN được <strong>tự tính theo tổng doanh thu</strong> của kỳ, theo quy định Chi cục Thuế (GTGT trực tiếp trên doanh thu, TNCN biểu 5 bậc 2026). Tỷ lệ % cấu hình tại Cài đặt doanh nghiệp.
    </MudAlert>

    <MudPaper Class="pa-2 mb-4" Elevation="1">
        <MudStack Row="true" Align="Align.Center" Spacing="2">
            <MudText Typo="Typo.body1">Kỳ kê khai:</MudText>
            <MudDatePicker @bind-Date="filterFrom" Label="Từ ngày" DateFormat="dd/MM/yyyy" Variant="Variant.Outlined" Dense="true" />
            <MudDatePicker @bind-Date="filterTo" Label="Đến ngày" DateFormat="dd/MM/yyyy" Variant="Variant.Outlined" Dense="true" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAll">Áp dụng</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetPeriod">
                Đặt lại
            </MudButton>
        </MudStack>
    </MudPaper>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
        <MudTabPanel Text="Thuế GTGT" Icon="@Icons.Material.Filled.Receipt">
            <MudPaper Class="pa-4 mb-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Thuế GTGT theo phương pháp trực tiếp trên doanh thu (quy định)</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudCard Outlined="true" Class="pa-3">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Tổng doanh thu kỳ (từ đơn hàng đã hoàn thành)</MudText>
                            <MudText Typo="Typo.h6">@tongDoanhThuKy.ToString("N0") ₫</MudText>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCard Outlined="true" Class="pa-3">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Tỷ lệ % (cài đặt doanh nghiệp)</MudText>
                            <MudText Typo="Typo.h6">@tyLeGTGT %</MudText>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCard Outlined="true" Class="pa-3" Style="background: var(--mud-palette-primary-lighten);">
                            <MudText Typo="Typo.body2"><strong>Thuế GTGT ước tính phải nộp</strong></MudText>
                            <MudText Typo="Typo.h5" Color="Color.Primary">@thueGTGTTuDoanhThu.ToString("N0") ₫</MudText>
                        </MudCard>
                    </MudItem>
                </MudGrid>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">Công thức: Doanh thu × Tỷ lệ % (theo Nghị định 123/2020). Chỉnh tỷ lệ tại Cài đặt doanh nghiệp.</MudText>
            </MudPaper>
            <MudExpansionPanels Class="mt-4">
                <MudExpansionPanel Text="Chi tiết đơn hàng hoàn thành trong kỳ (tham khảo)" IsInitiallyExpanded="false">
                    <MudTable T="SalesOrder" Items="@ordersInPeriod" Hover="true" Dense="true" Striped="true" Bordered="true" Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh>Số đơn</MudTh>
                            <MudTh>Ngày</MudTh>
                            <MudTh Align="Align.Right">Doanh thu</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.SoDonHang</MudTd>
                            <MudTd>@context.NgayDat.ToString("dd/MM/yyyy")</MudTd>
                            <MudTd Align="Align.Right">@context.TongTien.ToString("N0") ₫</MudTd>
                        </RowTemplate>
                        <NoRecordsContent><MudAlert Severity="Severity.Info">Không có hóa đơn trong kỳ.</MudAlert></NoRecordsContent>
                    </MudTable>
                </MudExpansionPanel>
                <MudExpansionPanel Text="Hóa đơn mua (tùy chọn, tham khảo)" IsInitiallyExpanded="false">
                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddPurchaseInvoice" Size="Size.Small">Thêm HĐ mua</MudButton>
                    </MudStack>
                    <MudTable T="PurchaseInvoice" Items="@purchaseInvoices" Hover="true" Dense="true" Striped="true" Bordered="true" Breakpoint="Breakpoint.Sm" Loading="@loadingPurchase">
                        <HeaderContent>
                            <MudTh>Số HĐ</MudTh>
                            <MudTh>Ngày</MudTh>
                            <MudTh>Nhà cung cấp</MudTh>
                            <MudTh Align="Align.Right">Tiền hàng</MudTh>
                            <MudTh Align="Align.Right">Thuế GTGT</MudTh>
                            <MudTh>Hành động</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.SoHoaDon</MudTd>
                            <MudTd>@context.NgayHoaDon.ToString("dd/MM/yyyy")</MudTd>
                            <MudTd>@context.NhaCungCap</MudTd>
                            <MudTd Align="Align.Right">@context.TienHangChuaThue.ToString("N0") ₫</MudTd>
                            <MudTd Align="Align.Right">@context.TienThueGTGT.ToString("N0") ₫</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => OpenEditPurchaseInvoice(context)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => DeletePurchaseInvoice(context)" />
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent><MudAlert Severity="Severity.Info">Chưa có hóa đơn mua.</MudAlert></NoRecordsContent>
                        <LoadingContent><MudProgressCircular Indeterminate="true" /></LoadingContent>
                    </MudTable>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudTabPanel>

        <MudTabPanel Text="Thuế TNCN" Icon="@Icons.Material.Filled.Person">
            <MudPaper Class="pa-4 mb-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Thuế TNCN tự tính theo doanh thu (quy định 2026, biểu 5 bậc)</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="3">
                        <MudCard Outlined="true" Class="pa-3">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Doanh thu kỳ</MudText>
                            <MudText Typo="Typo.body1">@tongDoanhThuKy.ToString("N0") ₫</MudText>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudCard Outlined="true" Class="pa-3">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Tỷ lệ thu nhập ước tính (%)</MudText>
                            <MudText Typo="Typo.body1">@tyLeThuNhapUocTinh %</MudText>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudCard Outlined="true" Class="pa-3">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Số tháng trong kỳ</MudText>
                            <MudText Typo="Typo.body1">@soThang</MudText>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudCard Outlined="true" Class="pa-3" Style="background: var(--mud-palette-primary-lighten);">
                            <MudText Typo="Typo.body2"><strong>Thuế TNCN ước tính (từ doanh thu)</strong></MudText>
                            <MudText Typo="Typo.h6" Color="Color.Primary">@thueTNCNUocTinhTuDoanhThu.ToString("N0") ₫</MudText>
                        </MudCard>
                    </MudItem>
                </MudGrid>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">Thu nhập ước tính = Doanh thu × Tỷ lệ %; quy về tháng, áp dụng giảm trừ gia cảnh và biểu thuế lũy tiến 5 bậc 2026.</MudText>
            </MudPaper>

            <MudPaper Class="pa-4 mb-4" Elevation="1">
                <MudStack Row="true" Justify="Justify.SpaceBetween" Align="Align.Center" Class="mb-3">
                    <MudText Typo="Typo.body1">Tổng thuế TNCN đã khấu trừ (từ bảng kê chi trả cá nhân)</MudText>
                    <MudChip T="string" Color="Color.Primary" Size="Size.Medium">@tongTNCNKhauTru.ToString("N0") ₫</MudChip>
                </MudStack>
                <MudTable T="WithholdingTax" Items="@withholdingList" Hover="true" Dense="true" Striped="true" Bordered="true" StickyHeader="true" Breakpoint="Breakpoint.Sm" Loading="@loadingWithholding">
                    <HeaderContent>
                        <MudTh>Ngày chi</MudTh>
                        <MudTh>Người nhận</MudTh>
                        <MudTh>Mã số thuế</MudTh>
                        <MudTh Align="Align.Right">Thu nhập chịu thuế</MudTh>
                        <MudTh Align="Align.Right">Thuế đã khấu trừ</MudTh>
                        <MudTh>Hành động</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.NgayChi.ToString("dd/MM/yyyy")</MudTd>
                        <MudTd>@context.NguoiNhan</MudTd>
                        <MudTd>@context.MaSoThue</MudTd>
                        <MudTd Align="Align.Right">@context.ThuNhapChiuThue.ToString("N0") ₫</MudTd>
                        <MudTd Align="Align.Right">@context.ThueKhauTru.ToString("N0") ₫</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => OpenEditWithholding(context)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteWithholding(context)" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent><MudAlert Severity="Severity.Info">Chưa có bản ghi khấu trừ TNCN trong kỳ.</MudAlert></NoRecordsContent>
                    <LoadingContent><MudProgressCircular Indeterminate="true" /></LoadingContent>
                </MudTable>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddWithholding" Class="mt-2">Thêm bản ghi khấu trừ</MudButton>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    [Inject] private ISalesOrderService SalesOrderService { get; set; } = default!;
    [Inject] private ICompanySettingService CompanySettingService { get; set; } = default!;
    [Inject] private IPurchaseInvoiceService PurchaseInvoiceService { get; set; } = default!;
    [Inject] private IWithholdingTaxService WithholdingTaxService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;

    private DateTime? filterFrom = DateTime.Now.AddMonths(-1);
    private DateTime? filterTo = DateTime.Now;
    private List<SalesOrder> allOrders = new();
    private List<PurchaseInvoice> purchaseInvoices = new();
    private List<WithholdingTax> withholdingList = new();
    private CompanySetting company = new();
    private bool loadingPurchase;
    private bool loadingWithholding;

    private List<SalesOrder> ordersInPeriod => allOrders
        .Where(o => (!filterFrom.HasValue || o.NgayDat >= filterFrom.Value) && (!filterTo.HasValue || o.NgayDat <= filterTo.Value))
        .Where(o => o.TrangThai == SalesOrderStatus.HoanThanh)
        .ToList();
    private decimal tongDoanhThuKy => ordersInPeriod.Sum(o => o.TongTien);
    private decimal tyLeGTGT => company.TyLeThueGTGTTrucTiep > 0 ? company.TyLeThueGTGTTrucTiep : 1;
    private decimal thueGTGTTuDoanhThu => TaxCalculator2026.TinhThueGTGTTrucTiep(tongDoanhThuKy, tyLeGTGT);
    private int soThang => (filterFrom.HasValue && filterTo.HasValue && filterTo.Value >= filterFrom.Value)
        ? Math.Max(1, (int)Math.Round((filterTo.Value - filterFrom.Value).TotalDays / 30.0))
        : 1;
    private decimal tyLeThuNhapUocTinh => company.TyLeThuNhapUocTinh > 0 ? company.TyLeThuNhapUocTinh : 30;
    private decimal thueTNCNUocTinhTuDoanhThu => TaxCalculator2026.UocTinhThueTNCNTuDoanhThu(tongDoanhThuKy, tyLeThuNhapUocTinh, soThang, 0);
    private decimal tongTNCNKhauTru => withholdingList.Sum(w => w.ThueKhauTru);

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        company = await CompanySettingService.GetAsync();
        allOrders = await SalesOrderService.GetAllAsync();
        await LoadPurchaseInvoices();
        await LoadWithholding();
    }

    private async Task ResetPeriod()
    {
        filterFrom = DateTime.Now.AddMonths(-1);
        filterTo = DateTime.Now;
        await LoadAll();
    }

    private async Task LoadPurchaseInvoices()
    {
        loadingPurchase = true;
        StateHasChanged();
        purchaseInvoices = await PurchaseInvoiceService.GetAllAsync(filterFrom, filterTo);
        loadingPurchase = false;
        StateHasChanged();
    }

    private async Task LoadWithholding()
    {
        loadingWithholding = true;
        StateHasChanged();
        withholdingList = await WithholdingTaxService.GetAllAsync(filterFrom, filterTo);
        loadingWithholding = false;
        StateHasChanged();
    }

    private async Task OpenAddPurchaseInvoice()
    {
        var item = new PurchaseInvoice { NgayHoaDon = filterTo ?? DateTime.Now };
        var parameters = new DialogParameters { ["Item"] = item };
        var dialog = await DialogService.ShowAsync<PurchaseInvoiceDialog>("Thêm hóa đơn mua", parameters);
        var result = await dialog.Result;
        if (result.Canceled || result.Data is not PurchaseInvoice saved) return;
        await PurchaseInvoiceService.AddAsync(saved);
        await LoadPurchaseInvoices();
        Snackbar.Add("Đã thêm hóa đơn mua.", Severity.Success);
    }

    private async Task OpenEditPurchaseInvoice(PurchaseInvoice item)
    {
        var copy = new PurchaseInvoice
        {
            Id = item.Id,
            SoHoaDon = item.SoHoaDon,
            NgayHoaDon = item.NgayHoaDon,
            NhaCungCap = item.NhaCungCap,
            TienHangChuaThue = item.TienHangChuaThue,
            ThueGTGT = item.ThueGTGT,
            TienThueGTGT = item.TienThueGTGT,
            GhiChu = item.GhiChu
        };
        var parameters = new DialogParameters { ["Item"] = copy };
        var dialog = await DialogService.ShowAsync<PurchaseInvoiceDialog>("Sửa hóa đơn mua", parameters);
        var result = await dialog.Result;
        if (result.Canceled || result.Data is not PurchaseInvoice updated) return;
        await PurchaseInvoiceService.UpdateAsync(updated);
        await LoadPurchaseInvoices();
        Snackbar.Add("Đã cập nhật.", Severity.Success);
    }

    private async Task DeletePurchaseInvoice(PurchaseInvoice item)
    {
        var parameters = new DialogParameters { ["ContentText"] = $"Xóa hóa đơn mua {item.SoHoaDon}?", ["ButtonText"] = "Xóa", ["Color"] = Color.Error };
        var dialog = await DialogService.ShowAsync<MessageBoxDialog>("Xác nhận", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;
        await PurchaseInvoiceService.DeleteAsync(item.Id);
        await LoadPurchaseInvoices();
        Snackbar.Add("Đã xóa.", Severity.Success);
    }

    private async Task OpenAddWithholding()
    {
        var item = new WithholdingTax { NgayChi = filterTo ?? DateTime.Now };
        var parameters = new DialogParameters { ["Item"] = item };
        var dialog = await DialogService.ShowAsync<WithholdingTaxDialog>("Thêm khấu trừ TNCN", parameters);
        var result = await dialog.Result;
        if (result.Canceled || result.Data is not WithholdingTax saved) return;
        await WithholdingTaxService.AddAsync(saved);
        await LoadWithholding();
        Snackbar.Add("Đã thêm bản ghi khấu trừ TNCN.", Severity.Success);
    }

    private async Task OpenEditWithholding(WithholdingTax item)
    {
        var copy = new WithholdingTax
        {
            Id = item.Id,
            NgayChi = item.NgayChi,
            NguoiNhan = item.NguoiNhan,
            MaSoThue = item.MaSoThue,
            ThuNhapChiuThue = item.ThuNhapChiuThue,
            ThueKhauTru = item.ThueKhauTru,
            GhiChu = item.GhiChu
        };
        var parameters = new DialogParameters { ["Item"] = copy };
        var dialog = await DialogService.ShowAsync<WithholdingTaxDialog>("Sửa khấu trừ TNCN", parameters);
        var result = await dialog.Result;
        if (result.Canceled || result.Data is not WithholdingTax updated) return;
        await WithholdingTaxService.UpdateAsync(updated);
        await LoadWithholding();
        Snackbar.Add("Đã cập nhật.", Severity.Success);
    }

    private async Task DeleteWithholding(WithholdingTax item)
    {
        var parameters = new DialogParameters { ["ContentText"] = $"Xóa bản ghi khấu trừ của {item.NguoiNhan}?", ["ButtonText"] = "Xóa", ["Color"] = Color.Error };
        var dialog = await DialogService.ShowAsync<MessageBoxDialog>("Xác nhận", parameters);
        var result = await dialog.Result;
        if (result.Canceled) return;
        await WithholdingTaxService.DeleteAsync(item.Id);
        await LoadWithholding();
        Snackbar.Add("Đã xóa.", Severity.Success);
    }
}
