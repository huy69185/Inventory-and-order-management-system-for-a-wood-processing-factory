@using MudBlazor
@using QuanLyKho.Application.Interfaces
@inherits LayoutComponentBase
@inject ICompanySettingService CompanySettingService
@inject NavigationManager Navigation

<MudThemeProvider Theme="MyTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <!-- Sidebar bên trái -->
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Variant="@DrawerVariant.Responsive">
        <MudDrawerHeader Class="py-4">
            <MudText Typo="Typo.h6" Class="ml-3" Style="color: var(--mud-palette-primary); font-weight: 600;">📦 Quản Lý Kho</MudText>
            <MudText Typo="Typo.caption" Class="ml-3 mt-0">Hóa đơn · Tồn kho · Báo cáo</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <!-- Nội dung chính -->
    <MudLayout>
        <!-- AppBar trên cùng -->
        <MudAppBar Elevation="1">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => _drawerOpen = !_drawerOpen)" />
            <MudSpacer />
            <MudText Typo="Typo.h6" Class="d-none d-sm-flex">Hệ thống Quản Lý Kho & Hóa Đơn Bán Hàng</MudText>
            <MudSpacer />
            <!-- Có thể thêm nút user hoặc logout sau -->
        </MudAppBar>

        <!-- Nội dung trang -->
        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 pa-4">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private MudTheme MyTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = Colors.Teal.Darken2,
            Secondary = Colors.Orange.Accent2,
            AppbarBackground = Colors.Teal.Darken3,
            Background = Colors.Gray.Lighten4
        },
        PaletteDark = new PaletteDark()
        {
            Primary = Colors.Teal.Lighten1,
            AppbarBackground = Colors.Teal.Darken4
        },
        LayoutProperties = new LayoutProperties()
        {
            DrawerWidthLeft = "280px"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        // Kiểm tra thiết lập công ty lần đầu (chỉ khi không ở trang setup)
        if (!Navigation.Uri.EndsWith("/setup-company", StringComparison.OrdinalIgnoreCase))
        {
            var setting = await CompanySettingService.GetAsync();
            if (string.IsNullOrWhiteSpace(setting.TenCongTy) ||
                string.IsNullOrWhiteSpace(setting.MaSoThue))
            {
                Navigation.NavigateTo("/setup-company");
            }
        }
    }
}